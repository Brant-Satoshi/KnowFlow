# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local (shared skills in .claude/skills/ are tracked)
.claude/*
!.claude/skills
CLAUDE.local.md

# playwright
/test-results
/playwright-report
/.playwright-mcp
/home-*.png
# storageState with a live session token — never commit
/playwright/.auth/

# pnpm local store (project-scoped cache)
/.pnpm-store

# agent worktrees
/.trees

# personal learning notebooks
/learning/

# drizzle-kit scratch output (handwritten SQL in db/migrations is the source of truth)
/drizzle

# runtime file uploads
/data/uploads/
